# API Keys — copy to .env and fill in your keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Unified proxy provider (e.g. dmxapi.cn) — if set, agents can use this via base_url
LLM_BASE_URL=
LLM_API_KEY=

# Optional: SerpAPI for web search (falls back to DuckDuckGo if not set)
SERPAPI_KEY=
